    "@types/node": "^22.15.0",
    "@types/react": "^19",
    "@types/react-katex": "^3.0.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-unused-imports": "^4",
    "husky": ">=6",
    "lint-staged": ">=10",
    "next-mdx-remote": "^6.0.0",
    "postcss": "^8.5.15",
    "prettier": "^2.4.1",
    "react-tweet-embed": "^2.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3"
