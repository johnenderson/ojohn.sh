    "@fortawesome/react-fontawesome": "^3.3.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@upstash/redis": "^1.38.0",
    "debounce": "^2.1.0",
    "feed": "^5.2.1",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "react": "^19",
    "react-dom": "^19",
    "react-intersection-observer": "^8.33.1",
    "react-katex": "^3.1.0",
    "reading-time": "^1.5.0",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
