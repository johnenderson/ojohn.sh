    "dev": "next dev",
    "prebuild": "yarn content:sync",
    "build": "next build",
    "start": "next start",
    "prelint": "yarn content:sync",
    "lint": "eslint app src --ext .ts,.tsx",
    "prettier:check": "prettier --check '**/*.{ts,tsx}'",
    "prettier:fix": "prettier --write '**/*.{ts,tsx}'",
